{
  "name": "aunboard",
  "version": "0.2.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Dev/staging React overlay that turns an app into a self-documenting one: click-to-record Explore badges and Walkthrough tours, replayed from durable DOM locators.",
  "keywords": [
    "react",
    "onboarding",
    "product-tour",
    "walkthrough",
    "tour",
    "overlay",
    "locator"
  ],
  "author": "Nikhil Tirunagiri",
  "homepage": "https://github.com/nikhiltirunagiri/aunboard#readme",
  "bugs": "https://github.com/nikhiltirunagiri/aunboard/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhiltirunagiri/aunboard.git",
    "directory": "packages/aunboard"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./record": {
      "import": { "types": "./dist/record/index.d.ts", "default": "./dist/record/index.js" },
      "require": { "types": "./dist/record/index.d.cts", "default": "./dist/record/index.cjs" }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup",
    "pack:tgz": "tsup && npm pack"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
